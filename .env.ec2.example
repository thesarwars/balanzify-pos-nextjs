# EC2 production environment — RDS + S3
# Copy to .env.ec2, fill in JWT_SECRET, then run: ./scripts/deploy-ec2.sh
#
# Generate JWT: openssl rand -hex 64

# ── RDS (required) ───────────────────────────────────────────────
# Password must be URL-encoded in DATABASE_URL if it contains special chars
# Example: | → %7C   ! → %21   > → %3E
DATABASE_URL=postgresql://postgres_dev:YOUR_URL_ENCODED_PASSWORD@balanzify-db-dev.c9gk2imws53j.us-east-2.rds.amazonaws.com:5432/balanzify_pos?schema=public
DB_HOST=balanzify-db-dev.c9gk2imws53j.us-east-2.rds.amazonaws.com
DB_PORT=5432
DB_NAME=balanzify_pos
DB_USER=postgres_dev
DB_PASSWORD=YOUR_RDS_PASSWORD

# ── Auth (required) ──────────────────────────────────────────────
JWT_SECRET=

# ── App ──────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
LOG_LEVEL=info
DOMAIN=18.221.211.50
FRONTEND_URL=http://18.221.211.50
ALLOWED_ORIGINS=http://18.221.211.50
REDIS_URL=redis://redis:6379

# ── AWS S3 (required for uploads) ────────────────────────────────
# EC2 IAM role is preferred — leave keys empty if role is attached
AWS_REGION=us-east-2
S3_BUCKET=balanzify-pos-s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
