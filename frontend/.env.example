# ── Frontend runtime configuration ──────────────────────────────────
# By default the app runs on its in-file MOCK backend (great for demos and
# offline development). To run as a real product against the live API, set:

# 'real' talks to the Express /api/v1 backend; anything else uses the mock.
NEXT_PUBLIC_API_MODE=real

# Base URL of the backend. Leave blank to use the same origin (when the app
# and API are served behind one domain). Otherwise point it at the backend.
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000
