# ════════════════════════════════════════════════════════════════════
#  Balanzify — Environment Variables
#  Copy this file to .env and fill in all required values.
#
#  Generate secrets:
#    openssl rand -hex 64   →  JWT_SECRET
#    openssl rand -hex 32   →  DB_PASSWORD
# ════════════════════════════════════════════════════════════════════

# ── DATABASE (required) ───────────────────────────────────────────
# Prisma uses DATABASE_URL directly.
# For docker-compose: assembled automatically from DB_* vars below.
# For manual/cloud installs: set DATABASE_URL directly.
DATABASE_URL=postgresql://balanzify:CHANGE_ME@localhost:5432/balanzify?schema=public

DB_NAME=balanzify
DB_USER=balanzify
DB_PASSWORD=CHANGE_ME                    # openssl rand -hex 32

# ── AUTHENTICATION (required) ────────────────────────────────────
JWT_SECRET=CHANGE_ME                     # openssl rand -hex 64 (min 64 chars)

# ── APPLICATION (required) ───────────────────────────────────────
FRONTEND_URL=https://yourdomain.com      # Used for CORS, receipt links, payment links
ALLOWED_ORIGINS=https://yourdomain.com   # Comma-separated for multiple origins
DOMAIN=yourdomain.com                    # Used by Nginx for SSL cert

# ── SERVER ───────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
LOG_LEVEL=info                           # error | warn | info | debug

# ── REDIS (optional) ─────────────────────────────────────────────
# Without Redis: in-memory rate limiting (single instance only)
# Required for: multi-instance deployments, ECS with >1 task
REDIS_URL=redis://localhost:6379

# ── EMAIL — choose ONE option ─────────────────────────────────────

# Option A: Generic SMTP (Gmail, Mailgun, SendGrid, Postmark, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
EMAIL_FROM=Balanzify <noreply@yourdomain.com>

# Option B: AWS SES (comment out SMTP_* if using SES)
# AWS_SES_REGION=us-east-1
# AWS_SES_SMTP_USER=your_ses_smtp_username
# AWS_SES_SMTP_PASS=your_ses_smtp_password

# ── FILE UPLOADS — AWS S3 (optional) ─────────────────────────────
# Without S3: product image and logo uploads will fail gracefully
S3_BUCKET=your-bucket-name
AWS_REGION=us-east-1
# AWS credentials — use IAM instance role (recommended) or keys:
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# ════════════════════════════════════════════════════════════════════
#  PAYMENT PROVIDERS
#  cash and credit are always enabled — no keys required.
#  Enable others by uncommenting and adding credentials.
# ════════════════════════════════════════════════════════════════════

# ── ZAAD — Telesom, Somaliland ───────────────────────────────────
# Works in manual_confirm mode without API keys (cashier enters reference)
# For QR tap-to-pay:
ZAAD_MERCHANT_TILL=your_till_number      # Merchant till number shown on QR
ZAAD_MERCHANT_NAME=Your Business Name    # Shown on QR and USSD prompt
# For automated push payments (when Telesom API is available):
# ZAAD_API_URL=https://api.telesom.so/zaad/v1
# ZAAD_MERCHANT_ID=your_merchant_id
# ZAAD_API_KEY=your_api_key

# ── EVC PLUS — Hormuud, Somalia ──────────────────────────────────
# EVC_MERCHANT_CODE=your_merchant_code
# EVC_MERCHANT_NAME=Your Business Name

# ── M-PESA — Safaricom Daraja API (Kenya + East Africa) ──────────
# MPESA_CONSUMER_KEY=your_consumer_key
# MPESA_CONSUMER_SECRET=your_consumer_secret
# MPESA_SHORTCODE=your_business_shortcode    # PayBill or Till number
# MPESA_PASSKEY=your_lipa_na_mpesa_passkey
# MPESA_MERCHANT_NAME=Your Business Name     # Shown in customer M-Pesa app
# MPESA_CALLBACK_URL=https://yourdomain.com/api/v1/payments/webhook/mpesa
# MPESA_ENV=sandbox                          # sandbox | production
# For reversals (refunds):
# MPESA_INITIATOR_NAME=your_initiator_name
# MPESA_SECURITY_CREDENTIAL=your_security_credential

# ── STRIPE — Card payments (Visa, Mastercard, Amex) ──────────────
# STRIPE_SECRET_KEY=sk_live_...             # or sk_test_... for testing
# STRIPE_WEBHOOK_SECRET=whsec_...           # from Stripe dashboard

# ── MOOV FINANCIAL — ACH bank transfers (US) ─────────────────────
# MOOV_API_KEY=your_api_key
# MOOV_API_SECRET=your_api_secret
# MOOV_ACCOUNT_ID=your_facilitator_account_id
# MOOV_WEBHOOK_SECRET=your_webhook_secret
# MOOV_ENV=sandbox                          # sandbox | production

# ── FUTURE PROVIDERS — uncomment when ready ──────────────────────
# AIRTEL_CLIENT_ID=                         # Airtel Money (pan-Africa)
# AIRTEL_CLIENT_SECRET=
# MTN_API_KEY=                              # MTN Mobile Money (pan-Africa)
# MTN_API_SECRET=
# FLW_SECRET_KEY=                           # Flutterwave (pan-Africa aggregator)
# FLW_ENCRYPTION_KEY=

# ════════════════════════════════════════════════════════════════════
#  CURRENCY
# ════════════════════════════════════════════════════════════════════

# Open Exchange Rates — live FX rates (optional)
# Without this: only manually configured rates are used
# Free tier: 1,000 requests/month. Sign up at https://openexchangerates.org
OPEN_EXCHANGE_RATES_APP_ID=your_app_id

# ════════════════════════════════════════════════════════════════════
#  RECEIPTS & CUSTOMER COMMUNICATIONS
# ════════════════════════════════════════════════════════════════════

# Digital receipt base URL
# Receipts are accessible at: {RECEIPT_BASE_URL}/r/{token}
# Defaults to FRONTEND_URL if not set
RECEIPT_BASE_URL=https://yourdomain.com

# ════════════════════════════════════════════════════════════════════
#  AI INSIGHTS
# ════════════════════════════════════════════════════════════════════

# Anthropic API — powers the merchant insights chat
# "Why did my sales drop?", "What should I reorder?", "How is my staff performing?"
# Responds in any language (Somali, Arabic, English, French, Swahili...)
# Without this key: insights return basic data summaries only (no AI)
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ════════════════════════════════════════════════════════════════════
#  HOTEL MODULE
# ════════════════════════════════════════════════════════════════════

# No additional env vars required beyond payment providers above.
# Hotel payments use the same payment registry (Zaad, M-Pesa, Stripe, cash).

# ════════════════════════════════════════════════════════════════════
#  SETTLEMENT PROVIDERS (configured via API, not env vars)
# ════════════════════════════════════════════════════════════════════

# Settlement providers (Premier Bank Somaliland, Equity Bank Kenya, etc.)
# are configured via POST /api/v1/credit/settlement/providers
# API credentials for each provider are stored encrypted in the database.
# No env vars needed — managed through the admin interface.

# ════════════════════════════════════════════════════════════════════
#  TESTING
# ════════════════════════════════════════════════════════════════════

# Test database — used by Jest integration tests
# Run scripts/setup-test-db.sh to create it
TEST_DATABASE_URL=postgresql://balanzify_test:password@localhost:5432/balanzify_test
