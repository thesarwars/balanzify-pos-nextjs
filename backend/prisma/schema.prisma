// Balanzify — Prisma Schema v1.0
// Prisma 6.12.0 + PostgreSQL
// Mirrors schema.sql exactly — every table, relation, enum, and index

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

