// Balanzify — Prisma Schema v1.0
// Prisma 6.12.0 + PostgreSQL
// Mirrors schema.sql exactly — every table, relation, enum, and index

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════════

enum UserRole {
  owner
  manager
  cashier
  warehouse
}

enum LocationType {
  warehouse
  store
  branch
}

enum StockMovementType {
  in
  out
  adjustment
  transfer_in
  transfer_out
  sale
  purchase
  waste
  return
  opening
}

enum AdjustmentType {
  write_off
  loss
  theft
  damage
  promo
  correction
  expiry
  found
}

enum AdjustmentStatus {
  pending
  approved
  rejected
}

enum TransferStatus {
  pending
  approved
  dispatched
  received
  cancelled
}

enum StockCountType {
  full
  partial
  cycle
}

enum StockCountStatus {
  in_progress
  completed
  approved
}

enum SupplierCommType {
  call
  email
  whatsapp
  meeting
  other
}

enum PurchaseOrderStatus {
  draft
  pending_approval
  approved
  sent
  partial
  received
  cancelled
}

enum POPaymentStatus {
  unpaid
  partial
  paid
}

enum SaleType {
  pos
  order
  invoice
  credit
}

enum SaleStatus {
  draft
  pending
  completed
  refunded
  partially_refunded
  cancelled
}

enum PaymentMethod {
  cash
  zaad
  visa
  mastercard
  split
  credit
}

enum DiscountType {
  pct
  flat
}

enum ShiftStatus {
  open
  closed
}

enum ProjectStatus {
  planning
  active
  on_hold
  completed
  cancelled
}

enum TaskCategory {
  other
  delivery
  maintenance
  admin
  purchase
  quality
  hr
  finance
}

enum TaskPriority {
  critical
  high
  medium
  low
}

enum TaskStatus {
  not_started
  in_progress
  blocked
  completed
  cancelled
}

enum MilestoneStatus {
  pending
  in_progress
  completed
  overdue
}

enum SerialNumberStatus {
  in_stock
  sold
  returned
  defective
}

enum CouponType {
  pct
  flat
  free_item
}

enum PettyCashType {
  in
  out
}

enum LoyaltyType {
  earn
  redeem
  adjust
  expire
}

enum ScheduledReportFrequency {
  daily
  weekly
  monthly
}

enum ScheduledReportType {
  sales
  inventory
  cashier
  low_stock
  profit
}

// ═══════════════════════════════════════════════════════════════════
// CORE
// ═══════════════════════════════════════════════════════════════════

model Business {
  id            String   @id @default(uuid()) @db.Uuid
  name          String   @db.VarChar(255)
  email         String   @unique @db.VarChar(255)
  phone         String?  @db.VarChar(50)
  address       String?
  city          String?  @db.VarChar(100)
  country       String?  @default("Somaliland") @db.VarChar(100)
  currency      String?  @default("USD") @db.VarChar(10)
  logoUrl       String?  @map("logo_url")
  logoKey       String?  @map("logo_key")
  receiptHeader String?  @map("receipt_header")
  receiptFooter String?  @default("Thank you for your business!") @map("receipt_footer")
  taxNumber     String?  @map("tax_number") @db.VarChar(100)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  // Relations
  users              User[]
  activityLogs       ActivityLog[]
  categories         Category[]
  locations          Location[]
  products           Product[]
  stockMovements     StockMovement[]
  stockAdjustments   StockAdjustment[]
  stockTransfers     StockTransfer[]
  stockCounts        StockCount[]
  suppliers          Supplier[]
  purchaseOrders     PurchaseOrder[]
  goodsReceivedNotes GoodsReceivedNote[]
  customers          Customer[]
  shifts             Shift[]
  heldSales          HeldSale[]
  sales              Sale[]
  refunds            Refund[]
  projects           Project[]
  tasks              Task[]
  notifications      Notification[]
  saleKeys           SaleKey[]
  refreshTokens      RefreshToken[]
  exchangeRates      ExchangeRate[]
  reorderSuggestions ReorderSuggestion[]
  loyaltyRules       LoyaltyRule[]
  loyaltyLedger      LoyaltyLedger[]
  coupons            Coupon[]
  pettyCash          PettyCash[]
  productBundles     ProductBundle[]
  serialNumbers      SerialNumber[]
  barcodeLabelJobs   BarcodeLabelJob[]
  costLayers         CostLayer[]
  supplierCatalogs   SupplierCatalog[]
  scheduledReports   ScheduledReport[]
  whatsappLogs       WhatsappLog[]
  salePayments       SalePayment[]
  taxRates           TaxRate[]
  webhookEndpoints   WebhookEndpoint[]
  webhookDeliveries  WebhookDelivery[]
  roomTypes          RoomType[]
  rooms              Room[]
  ratePlans          RatePlan[]
  reservations       Reservation[]
  folios             Folio[]
  folioCharges       FolioCharge[]
  folioPayments      FolioPayment[]
  housekeepingLogs   HousekeepingLog[]
  corporateAccounts  CorporateAccount[]
  modifierGroups     ModifierGroup[]
  restaurantTables   RestaurantTable[]
  restaurantOrders   RestaurantOrder[]
  kitchenTickets     KitchenTicket[]
  creditLedger       CreditLedger[]
  paymentPlans       PaymentPlan[]
  diasporaPayments   DiasporaPayment[]
  settlementAccounts SettlementAccount[]
  reservationGroups  ReservationGroup[]
  lostFoundItems     LostFound[]
  hotelSettings      HotelSettings?
  wholesaleOrders    WholesaleOrder[]
  expenses           Expense[]
  expenseCategories  ExpenseCategory[]
  paymentAccounts    PaymentAccount[]
  customerGroups     CustomerGroup[]
  units              Unit[]
  brands             Brand[]
  variationTemplates VariationTemplate[]

  // ── Module licensing: which products this business has enabled ──
  // Each module is sellable as a separate product (pos, inventory, hotel,
  // restaurant, pharmacy, credit, insights). Empty = all enabled (legacy).
  enabledModules String[] @default([]) @map("enabled_modules")
  // ── Market profile: drives currency, language, rails, compliance ──
  market         String   @default("somaliland") @db.VarChar(30)

  @@map("businesses")
}

model ExpenseCategory {
  id         String    @id @default(uuid()) @db.Uuid
  businessId String    @map("business_id") @db.Uuid
  name       String    @db.VarChar(255)
  createdAt  DateTime  @default(now()) @map("created_at")

  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  expenses   Expense[]

  @@unique([businessId, name])
  @@map("expense_categories")
}

model Expense {
  id            String   @id @default(uuid()) @db.Uuid
  businessId    String   @map("business_id") @db.Uuid
  categoryId    String?  @map("category_id") @db.Uuid
  locationId    String?  @map("location_id") @db.Uuid
  expenseNumber String   @map("expense_number") @db.VarChar(50)
  amount        Decimal  @db.Decimal(12, 2)
  paymentStatus String   @default("paid") @map("payment_status") @db.VarChar(20)
  expenseFor    String?  @map("expense_for") @db.VarChar(255)
  note          String?
  isRefund      Boolean  @default(false) @map("is_refund")
  expenseDate   DateTime @map("expense_date")
  createdById   String?  @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")

  business  Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category  ExpenseCategory? @relation(fields: [categoryId], references: [id])
  location  Location?        @relation(fields: [locationId], references: [id])
  createdBy User?            @relation(fields: [createdById], references: [id])

  @@index([businessId, expenseDate])
  @@map("expenses")
}

model Unit {
  id           String   @id @default(uuid()) @db.Uuid
  businessId   String   @map("business_id") @db.Uuid
  actualName   String   @map("actual_name") @db.VarChar(100)
  shortName    String   @map("short_name") @db.VarChar(20)
  allowDecimal Boolean  @default(false) @map("allow_decimal")
  createdAt    DateTime @default(now()) @map("created_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("units")
}

model Brand {
  id         String    @id @default(uuid()) @db.Uuid
  businessId String    @map("business_id") @db.Uuid
  name       String    @db.VarChar(255)
  createdAt  DateTime  @default(now()) @map("created_at")

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([businessId, name])
  @@map("brands")
}

model VariationTemplate {
  id         String   @id @default(uuid()) @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  name       String   @db.VarChar(100)
  values     String[] @default([])
  createdAt  DateTime @default(now()) @map("created_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("variation_templates")
}

model CustomerGroup {
  id          String     @id @default(uuid()) @db.Uuid
  businessId  String     @map("business_id") @db.Uuid
  name        String     @db.VarChar(255)
  discountPct Decimal    @default(0) @map("discount_pct") @db.Decimal(6, 2)
  createdAt   DateTime   @default(now()) @map("created_at")

  business    Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customers   Customer[]

  @@unique([businessId, name])
  @@map("customer_groups")
}

model PaymentAccount {
  id            String   @id @default(uuid()) @db.Uuid
  businessId    String   @map("business_id") @db.Uuid
  name          String   @db.VarChar(255)
  type          String   @default("Cash") @db.VarChar(30)
  accountNumber String?  @map("account_number") @db.VarChar(100)
  balance       Decimal  @default(0) @db.Decimal(14, 2)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("payment_accounts")
}

model User {
  id                String    @id @default(uuid()) @db.Uuid
  businessId        String?   @map("business_id") @db.Uuid
  name              String    @db.VarChar(255)
  email             String    @unique @db.VarChar(255)
  password          String    @db.VarChar(255)
  role              UserRole  @default(cashier)
  pin               String?   @db.VarChar(10)
  isActive          Boolean   @default(true) @map("is_active")
  lastLogin         DateTime? @map("last_login")
  tokenVersion      Int       @default(0) @map("token_version")
  mfaSecret         String?   @map("mfa_secret") @db.VarChar(64)
  mfaEnabled        Boolean   @default(false) @map("mfa_enabled")
  mfaBackupCodes    Json?     @map("mfa_backup_codes")
  passwordChangedAt DateTime? @map("password_changed_at")
  failedLoginCount  Int       @default(0) @map("failed_login_count")
  lockedUntil       DateTime? @map("locked_until")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")

  // Relations
  business                 Business?               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  activityLogs             ActivityLog[]
  stockMovements           StockMovement[]
  stockAdjustmentsApproved StockAdjustment[]       @relation("approver")
  stockAdjustmentsCreated  StockAdjustment[]       @relation("creator")
  stockTransfersApproved   StockTransfer[]         @relation("transfer_approver")
  stockTransfersCreated    StockTransfer[]         @relation("transfer_creator")
  stockCountsApproved      StockCount[]            @relation("count_approver")
  stockCountsCreated       StockCount[]            @relation("count_creator")
  stockCountItems          StockCountItem[]
  supplierComms            SupplierCommunication[]
  purchaseOrdersApproved   PurchaseOrder[]         @relation("po_approver")
  purchaseOrdersCreated    PurchaseOrder[]         @relation("po_creator")
  goodsReceivedNotes       GoodsReceivedNote[]
  poPayments               POPayment[]
  shifts                   Shift[]
  heldSales                HeldSale[]
  salesCashier             Sale[]
  refunds                  Refund[]
  expenses                 Expense[]
  projectsOwned            Project[]               @relation("project_owner")
  projectsCreated          Project[]               @relation("project_creator")
  milestones               Milestone[]
  tasksAssigned            Task[]                  @relation("task_assignee")
  tasksCreated             Task[]                  @relation("task_creator")
  taskComments             TaskComment[]
  notifications            Notification[]
  saleKeys                 SaleKey[]
  refreshTokens            RefreshToken[]
  passwordResetTokens      PasswordResetToken[]
  loyaltyLedger            LoyaltyLedger[]
  couponsCreated           Coupon[]
  pettyCash                PettyCash[]
  barcodeLabelJobs         BarcodeLabelJob[]
  scheduledReports         ScheduledReport[]
  reorderSuggestions       ReorderSuggestion[]     @relation("preferred_supplier_contact")
  productVariantsCreated   ProductVariant[]
  reservationsCreated      Reservation[]           @relation("reservation_creator")
  reservationsCheckedIn    Reservation[]           @relation("reservation_checkin")
  reservationsCheckedOut   Reservation[]           @relation("reservation_checkout")
  foliosSettled            Folio[]                 @relation("folio_settler")
  folioChargesPosted       FolioCharge[]           @relation("charge_poster")
  folioPaymentsReceived    FolioPayment[]          @relation("payment_receiver")
  housekeepingAssigned     HousekeepingLog[]       @relation("housekeeper")
  restaurantOrders         RestaurantOrder[]       @relation("order_staff")

  lostFoundFound  LostFound[]  @relation("lost_found_finder")

  @@map("users")
}

model ActivityLog {
  id         String   @id @default(uuid()) @db.Uuid
  businessId String?  @map("business_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(100)
  entityType String?  @map("entity_type") @db.VarChar(50)
  entityId   String?  @map("entity_id") @db.Uuid
  details    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  business Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User?     @relation(fields: [userId], references: [id])

  @@index([businessId, createdAt])
  @@map("activity_log")
}

// ═══════════════════════════════════════════════════════════════════
// INVENTORY
// ═══════════════════════════════════════════════════════════════════

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  businessId  String   @map("business_id") @db.Uuid
  name        String   @db.VarChar(255)
  description String?
  color       String?  @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at")

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products Product[]

  @@map("categories")
}

model Location {
  id         String       @id @default(uuid()) @db.Uuid
  businessId String       @map("business_id") @db.Uuid
  name       String       @db.VarChar(255)
  type       LocationType @default(warehouse)
  address    String?
  isActive   Boolean      @default(true) @map("is_active")
  createdAt  DateTime     @default(now()) @map("created_at")

  business           Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  stockLevels        StockLevel[]
  stockBatches       StockBatch[]
  stockMovements     StockMovement[]
  stockAdjustments   StockAdjustment[]
  stockTransfersFrom StockTransfer[]     @relation("from_location")
  stockTransfersTo   StockTransfer[]     @relation("to_location")
  stockCounts        StockCount[]
  purchaseOrders     PurchaseOrder[]
  shifts             Shift[]
  sales              Sale[]
  reorderSuggestions ReorderSuggestion[]
  expenses           Expense[]
  serialNumbers      SerialNumber[]
  costLayers         CostLayer[]
  pettyCash          PettyCash[]
  productVariants    ProductVariant[]    @relation("variant_stock_location")

  @@map("locations")
}

model Product {
  id                 String   @id @default(uuid()) @db.Uuid
  businessId         String   @map("business_id") @db.Uuid
  categoryId         String?  @map("category_id") @db.Uuid
  brandId            String?  @map("brand_id") @db.Uuid
  name               String   @db.VarChar(255)
  sku                String?  @db.VarChar(100)
  barcode            String?  @db.VarChar(100)
  description        String?
  unitOfMeasure      String   @default("unit") @map("unit_of_measure") @db.VarChar(50)
  costPrice          Decimal  @default(0) @map("cost_price") @db.Decimal(12, 2)
  sellingPrice       Decimal  @default(0) @map("selling_price") @db.Decimal(12, 2)
  wholesalePrice     Decimal  @default(0) @map("wholesale_price") @db.Decimal(12, 2)
  minStockLevel      Int      @default(0) @map("min_stock_level")
  maxStockLevel      Int      @default(0) @map("max_stock_level")
  reorderPoint       Int      @default(0) @map("reorder_point")
  trackExpiry        Boolean  @default(false) @map("track_expiry")
  kitchenStation     String?  @map("kitchen_station") @db.VarChar(50)
  // ── Pharmacy fields (active when pharmacy module enabled) ──
  genericName        String?  @map("generic_name") @db.VarChar(255)
  strength           String?  @db.VarChar(50)
  formulation        String?  @db.VarChar(50)
  manufacturer       String?  @db.VarChar(255)
  isPrescriptionDrug Boolean  @default(false) @map("is_prescription_drug")
  // ── Partial-pack / unit selling ──
  packSize           Int?     @map("pack_size")
  sellByUnit         Boolean  @default(false) @map("sell_by_unit")
  unitName           String?  @map("unit_name") @db.VarChar(30)
  unitPrice          Decimal? @map("unit_price") @db.Decimal(12, 2)
  allowPriceOverride Boolean  @default(true) @map("allow_price_override")
  isActive           Boolean  @default(true) @map("is_active")
  isSerialized       Boolean  @default(false) @map("is_serialised")
  imageUrl           String?  @map("image_url")
  imageKey           String?  @map("image_key")
  notes              String?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  business           Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category           Category?              @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brand              Brand?                 @relation(fields: [brandId], references: [id], onDelete: SetNull)
  stockLevels        StockLevel[]
  stockBatches       StockBatch[]
  stockMovements     StockMovement[]
  stockAdjustments   StockAdjustment[]
  stockTransferItems StockTransferItem[]
  stockCountItems    StockCountItem[]
  supplierProducts   SupplierProduct[]
  purchaseOrderItems PurchaseOrderItem[]
  saleItems          SaleItem[]
  refundItems        RefundItem[]
  reorderSuggestions ReorderSuggestion[]
  variants           ProductVariant[]
  bundleItems        ProductBundleItem[]
  serialNumbers      SerialNumber[]
  taxRate            TaxRate?               @relation(fields: [taxRateId], references: [id])
  taxRateId          String?                @map("tax_rate_id") @db.Uuid
  costLayers         CostLayer[]
  supplierCatalogs   SupplierCatalog[]      @relation("catalog_product")
  modifierGroups     ProductModifierGroup[]
  orderItems         OrderItem[]            @relation("menu_item")

  wholesaleOrderItems WholesaleOrderItem[] @relation("wholesale_item_product")
  @@index([businessId])
  @@index([barcode])
  @@index([sku])
  @@map("products")
}

model ProductVariant {
  id             String   @id @default(uuid()) @db.Uuid
  productId      String   @map("product_id") @db.Uuid
  sku            String?  @db.VarChar(100)
  barcode        String?  @db.VarChar(100)
  attributes     Json     @default("{}")
  costPrice      Decimal  @default(0) @map("cost_price") @db.Decimal(12, 2)
  sellingPrice   Decimal  @default(0) @map("selling_price") @db.Decimal(12, 2)
  wholesalePrice Decimal  @default(0) @map("wholesale_price") @db.Decimal(12, 2)
  isActive       Boolean  @default(true) @map("is_active")
  imageUrl       String?  @map("image_url")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  product               Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  stockLevels           StockLevel[]
  stockMovements        StockMovement[]
  saleItems             SaleItem[]
  purchaseOrderItems    PurchaseOrderItem[]
  bundleItems           ProductBundleItem[]
  taxRate               TaxRate?            @relation(fields: [taxRateId], references: [id])
  taxRateId             String?             @map("tax_rate_id") @db.Uuid
  costLayers            CostLayer[]
  createdBy             User?               @relation(fields: [createdById], references: [id])
  createdById           String?             @map("created_by") @db.Uuid
  variantStockLocations Location[]          @relation("variant_stock_location")
  orderItems            OrderItem[]         @relation("menu_variant")

  @@index([productId])
  @@index([sku])
  @@index([barcode])
  @@map("product_variants")
}

model StockLevel {
  id         String   @id @default(uuid()) @db.Uuid
  productId  String   @map("product_id") @db.Uuid
  variantId  String?  @map("variant_id") @db.Uuid
  locationId String   @map("location_id") @db.Uuid
  quantity   Int      @default(0)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  product  Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant  ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  location Location        @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([productId, locationId])
  @@index([productId])
  @@map("stock_levels")
}

model StockBatch {
  id           String    @id @default(uuid()) @db.Uuid
  productId    String    @map("product_id") @db.Uuid
  locationId   String    @map("location_id") @db.Uuid
  batchNumber  String?   @map("batch_number") @db.VarChar(100)
  lotNumber    String?   @map("lot_number") @db.VarChar(100)
  quantity     Int       @default(0)
  costPrice    Decimal   @default(0) @map("cost_price") @db.Decimal(12, 2)
  expiryDate   DateTime? @map("expiry_date") @db.Date
  receivedDate DateTime  @default(now()) @map("received_date") @db.Date
  createdAt    DateTime  @default(now()) @map("created_at")

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([expiryDate])
  @@map("stock_batches")
}

model StockMovement {
  id            String            @id @default(uuid()) @db.Uuid
  businessId    String            @map("business_id") @db.Uuid
  productId     String            @map("product_id") @db.Uuid
  variantId     String?           @map("variant_id") @db.Uuid
  locationId    String            @map("location_id") @db.Uuid
  type          StockMovementType
  quantity      Int
  balanceAfter  Int?              @map("balance_after")
  referenceId   String?           @map("reference_id") @db.Uuid
  referenceType String?           @map("reference_type") @db.VarChar(50)
  notes         String?
  createdById   String?           @map("created_by") @db.Uuid
  createdAt     DateTime          @default(now()) @map("created_at")

  business  Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  location  Location        @relation(fields: [locationId], references: [id], onDelete: Cascade)
  createdBy User?           @relation(fields: [createdById], references: [id])

  @@index([productId])
  @@index([businessId, createdAt])
  @@map("stock_movements")
}

model StockAdjustment {
  id           String           @id @default(uuid()) @db.Uuid
  businessId   String           @map("business_id") @db.Uuid
  productId    String           @map("product_id") @db.Uuid
  locationId   String           @map("location_id") @db.Uuid
  type         AdjustmentType
  quantity     Int
  unitCost     Decimal          @default(0) @map("unit_cost") @db.Decimal(12, 2)
  totalValue   Decimal          @default(0) @map("total_value") @db.Decimal(12, 2)
  reason       String?
  photoUrl     String?          @map("photo_url")
  approvedById String?          @map("approved_by") @db.Uuid
  approvedAt   DateTime?        @map("approved_at")
  status       AdjustmentStatus @default(pending)
  createdById  String?          @map("created_by") @db.Uuid
  createdAt    DateTime         @default(now()) @map("created_at")

  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  approvedBy User?    @relation("approver", fields: [approvedById], references: [id])
  createdBy  User?    @relation("creator", fields: [createdById], references: [id])

  @@map("stock_adjustments")
}

model StockTransfer {
  id             String         @id @default(uuid()) @db.Uuid
  businessId     String         @map("business_id") @db.Uuid
  transferNumber String?        @unique @map("transfer_number") @db.VarChar(50)
  fromLocationId String         @map("from_location_id") @db.Uuid
  toLocationId   String         @map("to_location_id") @db.Uuid
  status         TransferStatus @default(pending)
  notes          String?
  approvedById   String?        @map("approved_by") @db.Uuid
  dispatchedAt   DateTime?      @map("dispatched_at")
  receivedAt     DateTime?      @map("received_at")
  createdById    String?        @map("created_by") @db.Uuid
  createdAt      DateTime       @default(now()) @map("created_at")

  business     Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  fromLocation Location            @relation("from_location", fields: [fromLocationId], references: [id])
  toLocation   Location            @relation("to_location", fields: [toLocationId], references: [id])
  approvedBy   User?               @relation("transfer_approver", fields: [approvedById], references: [id])
  createdBy    User?               @relation("transfer_creator", fields: [createdById], references: [id])
  items        StockTransferItem[]

  @@map("stock_transfers")
}

model StockTransferItem {
  id            String @id @default(uuid()) @db.Uuid
  transferId    String @map("transfer_id") @db.Uuid
  productId     String @map("product_id") @db.Uuid
  requestedQty  Int    @map("requested_qty")
  dispatchedQty Int    @default(0) @map("dispatched_qty")
  receivedQty   Int    @default(0) @map("received_qty")

  transfer StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  product  Product       @relation(fields: [productId], references: [id])

  @@map("stock_transfer_items")
}

model StockCount {
  id           String           @id @default(uuid()) @db.Uuid
  businessId   String           @map("business_id") @db.Uuid
  locationId   String?          @map("location_id") @db.Uuid
  name         String?          @db.VarChar(255)
  type         StockCountType   @default(full)
  status       StockCountStatus @default(in_progress)
  notes        String?
  approvedById String?          @map("approved_by") @db.Uuid
  approvedAt   DateTime?        @map("approved_at")
  createdById  String?          @map("created_by") @db.Uuid
  createdAt    DateTime         @default(now()) @map("created_at")

  business   Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location   Location?        @relation(fields: [locationId], references: [id])
  approvedBy User?            @relation("count_approver", fields: [approvedById], references: [id])
  createdBy  User?            @relation("count_creator", fields: [createdById], references: [id])
  items      StockCountItem[]

  @@map("stock_counts")
}

model StockCountItem {
  id          String    @id @default(uuid()) @db.Uuid
  countId     String    @map("count_id") @db.Uuid
  productId   String    @map("product_id") @db.Uuid
  systemQty   Int       @default(0) @map("system_qty")
  countedQty  Int?      @map("counted_qty")
  countedById String?   @map("counted_by") @db.Uuid
  countedAt   DateTime? @map("counted_at")

  count     StockCount @relation(fields: [countId], references: [id], onDelete: Cascade)
  product   Product    @relation(fields: [productId], references: [id])
  countedBy User?      @relation(fields: [countedById], references: [id])

  @@map("stock_count_items")
}

// ═══════════════════════════════════════════════════════════════════
// SUPPLIERS
// ═══════════════════════════════════════════════════════════════════

model Supplier {
  id                 String   @id @default(uuid()) @db.Uuid
  businessId         String   @map("business_id") @db.Uuid
  name               String   @db.VarChar(255)
  contactPerson      String?  @map("contact_person") @db.VarChar(255)
  phone              String?  @db.VarChar(50)
  whatsapp           String?  @db.VarChar(50)
  email              String?  @db.VarChar(255)
  country            String?  @db.VarChar(100)
  city               String?  @db.VarChar(100)
  address            String?
  paymentTerms       Int      @default(0) @map("payment_terms")
  creditLimit        Decimal  @default(0) @map("credit_limit") @db.Decimal(12, 2)
  outstandingBalance Decimal  @default(0) @map("outstanding_balance") @db.Decimal(12, 2)
  currency           String   @default("USD") @db.VarChar(10)
  rating             Int      @default(0)
  isBlacklisted      Boolean  @default(false) @map("is_blacklisted")
  blacklistReason    String?  @map("blacklist_reason")
  isActive           Boolean  @default(true) @map("is_active")
  notes              String?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  business           Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products           SupplierProduct[]
  communications     SupplierCommunication[]
  purchaseOrders     PurchaseOrder[]
  reorderSuggestions ReorderSuggestion[]
  catalog            SupplierCatalog[]

  @@map("suppliers")
}

model SupplierProduct {
  id           String  @id @default(uuid()) @db.Uuid
  supplierId   String  @map("supplier_id") @db.Uuid
  productId    String  @map("product_id") @db.Uuid
  supplierSku  String? @map("supplier_sku") @db.VarChar(100)
  unitPrice    Decimal @default(0) @map("unit_price") @db.Decimal(12, 2)
  minOrderQty  Int     @default(1) @map("min_order_qty")
  leadTimeDays Int     @default(0) @map("lead_time_days")
  isPreferred  Boolean @default(false) @map("is_preferred")

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([supplierId, productId])
  @@map("supplier_products")
}

model SupplierCommunication {
  id          String           @id @default(uuid()) @db.Uuid
  supplierId  String           @map("supplier_id") @db.Uuid
  type        SupplierCommType
  subject     String?          @db.VarChar(255)
  notes       String?
  createdById String?          @map("created_by") @db.Uuid
  createdAt   DateTime         @default(now()) @map("created_at")

  supplier  Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  createdBy User?    @relation(fields: [createdById], references: [id])

  @@map("supplier_communications")
}

model SupplierCatalog {
  id           String   @id @default(uuid()) @db.Uuid
  supplierId   String   @map("supplier_id") @db.Uuid
  businessId   String   @map("business_id") @db.Uuid
  productName  String   @map("product_name") @db.VarChar(255)
  supplierSku  String?  @map("supplier_sku") @db.VarChar(100)
  barcode      String?  @db.VarChar(100)
  unitPrice    Decimal  @map("unit_price") @db.Decimal(12, 2)
  currency     String   @default("USD") @db.VarChar(3)
  minOrderQty  Int      @default(1) @map("min_order_qty")
  leadTimeDays Int      @default(0) @map("lead_time_days")
  isAvailable  Boolean  @default(true) @map("is_available")
  importedAt   DateTime @default(now()) @map("imported_at")

  supplier  Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  business  Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  product   Product? @relation("catalog_product", fields: [productId], references: [id])
  productId String?  @map("product_id") @db.Uuid

  @@index([supplierId])
  @@map("supplier_catalog")
}

// ═══════════════════════════════════════════════════════════════════
// PURCHASE ORDERS
// ═══════════════════════════════════════════════════════════════════

model PurchaseOrder {
  id               String              @id @default(uuid()) @db.Uuid
  businessId       String              @map("business_id") @db.Uuid
  supplierId       String?             @map("supplier_id") @db.Uuid
  locationId       String?             @map("location_id") @db.Uuid
  poNumber         String?             @unique @map("po_number") @db.VarChar(50)
  status           PurchaseOrderStatus @default(draft)
  orderDate        DateTime            @default(now()) @map("order_date") @db.Date
  expectedDelivery DateTime?           @map("expected_delivery") @db.Date
  subtotal         Decimal             @default(0) @db.Decimal(12, 2)
  taxAmount        Decimal             @default(0) @map("tax_amount") @db.Decimal(12, 2)
  freightCost      Decimal             @default(0) @map("freight_cost") @db.Decimal(12, 2)
  customsDuty      Decimal             @default(0) @map("customs_duty") @db.Decimal(12, 2)
  otherCharges     Decimal             @default(0) @map("other_charges") @db.Decimal(12, 2)
  totalAmount      Decimal             @default(0) @map("total_amount") @db.Decimal(12, 2)
  amountPaid       Decimal             @default(0) @map("amount_paid") @db.Decimal(12, 2)
  currency         String              @default("USD") @db.VarChar(10)
  exchangeRate     Decimal             @default(1) @map("exchange_rate") @db.Decimal(10, 4)
  paymentTerms     Int                 @default(0) @map("payment_terms")
  paymentStatus    POPaymentStatus     @default(unpaid) @map("payment_status")
  notes            String?
  sentVia          String?             @map("sent_via") @db.VarChar(20)
  sentAt           DateTime?           @map("sent_at")
  approvedById     String?             @map("approved_by") @db.Uuid
  approvedAt       DateTime?           @map("approved_at")
  createdById      String?             @map("created_by") @db.Uuid
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @default(now()) @updatedAt @map("updated_at")

  business           Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplier           Supplier?           @relation(fields: [supplierId], references: [id])
  location           Location?           @relation(fields: [locationId], references: [id])
  approvedBy         User?               @relation("po_approver", fields: [approvedById], references: [id])
  createdBy          User?               @relation("po_creator", fields: [createdById], references: [id])
  items              PurchaseOrderItem[]
  goodsReceivedNotes GoodsReceivedNote[]
  payments           POPayment[]
  serialNumbers      SerialNumber[]
  taxRate            TaxRate?            @relation(fields: [taxRateId], references: [id])
  taxRateId          String?             @map("tax_rate_id") @db.Uuid
  costLayers         CostLayer[]

  @@index([businessId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id          String    @id @default(uuid()) @db.Uuid
  poId        String    @map("po_id") @db.Uuid
  productId   String    @map("product_id") @db.Uuid
  variantId   String?   @map("variant_id") @db.Uuid
  orderedQty  Int       @map("ordered_qty")
  receivedQty Int       @default(0) @map("received_qty")
  unitPrice   Decimal   @map("unit_price") @db.Decimal(12, 2)
  totalPrice  Decimal   @map("total_price") @db.Decimal(12, 2)
  expiryDate  DateTime? @map("expiry_date") @db.Date
  batchNumber String?   @map("batch_number") @db.VarChar(100)
  notes       String?

  purchaseOrder PurchaseOrder   @relation(fields: [poId], references: [id], onDelete: Cascade)
  product       Product         @relation(fields: [productId], references: [id])
  variant       ProductVariant? @relation(fields: [variantId], references: [id])

  @@map("purchase_order_items")
}

model GoodsReceivedNote {
  id           String   @id @default(uuid()) @db.Uuid
  poId         String   @map("po_id") @db.Uuid
  businessId   String   @map("business_id") @db.Uuid
  grnNumber    String?  @unique @map("grn_number") @db.VarChar(50)
  receivedDate DateTime @default(now()) @map("received_date") @db.Date
  notes        String?
  createdById  String?  @map("created_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id])
  business      Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdBy     User?         @relation(fields: [createdById], references: [id])

  @@map("goods_received_notes")
}

model POPayment {
  id            String   @id @default(uuid()) @db.Uuid
  poId          String   @map("po_id") @db.Uuid
  amount        Decimal  @db.Decimal(12, 2)
  paymentMethod String?  @map("payment_method") @db.VarChar(30)
  reference     String?  @db.VarChar(100)
  notes         String?
  createdById   String?  @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")

  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  createdBy     User?         @relation(fields: [createdById], references: [id])

  @@map("po_payments")
}

// ═══════════════════════════════════════════════════════════════════
// CUSTOMERS
// ═══════════════════════════════════════════════════════════════════

model Customer {
  id                 String   @id @default(uuid()) @db.Uuid
  businessId         String   @map("business_id") @db.Uuid
  name               String   @db.VarChar(255)
  phone              String?  @db.VarChar(50)
  whatsapp           String?  @db.VarChar(50)
  email              String?  @db.VarChar(255)
  address            String?
  creditLimit        Decimal  @default(0) @map("credit_limit") @db.Decimal(12, 2)
  outstandingBalance Decimal  @default(0) @map("outstanding_balance") @db.Decimal(12, 2)
  totalPurchases     Decimal  @default(0) @map("total_purchases") @db.Decimal(12, 2)
  loyaltyPoints      Int      @default(0) @map("loyalty_points")
  segment            String?  @db.VarChar(50)
  customerGroupId    String?  @map("customer_group_id") @db.Uuid
  whatsappOptedIn    Boolean  @default(true) @map("whatsapp_opted_in")
  diasporaCurrency   String   @default("USD") @map("diaspora_currency") @db.VarChar(3)
  notes              String?
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  business         Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerGroup    CustomerGroup?    @relation(fields: [customerGroupId], references: [id])
  sales            Sale[]
  loyaltyLedger    LoyaltyLedger[]
  reservations     Reservation[]
  folios           Folio[]           @relation("guest_folios")
  restaurantOrders RestaurantOrder[] @relation("restaurant_customer")
  creditLedger     CreditLedger[]
  paymentPlans     PaymentPlan[]
  diasporaPayments DiasporaPayment[]

  lostFoundItems  LostFound[]  @relation("lost_found_guest")

  wholesaleOrders WholesaleOrder[] @relation("wholesale_customer")
  @@map("customers")
}

// ═══════════════════════════════════════════════════════════════════
// SALES & POS
// ═══════════════════════════════════════════════════════════════════

model Shift {
  id                String      @id @default(uuid()) @db.Uuid
  businessId        String      @map("business_id") @db.Uuid
  locationId        String?     @map("location_id") @db.Uuid
  cashierId         String?     @map("cashier_id") @db.Uuid
  openingFloat      Decimal     @default(0) @map("opening_float") @db.Decimal(12, 2)
  closingFloat      Decimal?    @map("closing_float") @db.Decimal(12, 2)
  expectedCash      Decimal?    @map("expected_cash") @db.Decimal(12, 2)
  actualCash        Decimal?    @map("actual_cash") @db.Decimal(12, 2)
  variance          Decimal?    @db.Decimal(12, 2)
  totalSales        Decimal     @default(0) @map("total_sales") @db.Decimal(12, 2)
  totalTransactions Int         @default(0) @map("total_transactions")
  totalCash         Decimal     @default(0) @map("total_cash") @db.Decimal(12, 2)
  totalZaad         Decimal     @default(0) @map("total_zaad") @db.Decimal(12, 2)
  totalCard         Decimal     @default(0) @map("total_card") @db.Decimal(12, 2)
  status            ShiftStatus @default(open)
  notes             String?
  openedAt          DateTime    @default(now()) @map("opened_at")
  closedAt          DateTime?   @map("closed_at")

  business  Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location  Location?   @relation(fields: [locationId], references: [id])
  cashier   User?       @relation(fields: [cashierId], references: [id])
  sales     Sale[]
  heldSales HeldSale[]
  pettyCash PettyCash[]

  @@map("shifts")
}

model HeldSale {
  id           String   @id @default(uuid()) @db.Uuid
  businessId   String   @map("business_id") @db.Uuid
  shiftId      String?  @map("shift_id") @db.Uuid
  label        String?  @db.VarChar(100)
  customerName String?  @map("customer_name") @db.VarChar(255)
  items        Json
  subtotal     Decimal? @db.Decimal(12, 2)
  createdById  String?  @map("created_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  business  Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  shift     Shift?   @relation(fields: [shiftId], references: [id])
  createdBy User?    @relation(fields: [createdById], references: [id])

  @@index([businessId])
  @@map("held_sales")
}

model Sale {
  id                    String        @id @default(uuid()) @db.Uuid
  businessId            String        @map("business_id") @db.Uuid
  shiftId               String?       @map("shift_id") @db.Uuid
  locationId            String?       @map("location_id") @db.Uuid
  customerId            String?       @map("customer_id") @db.Uuid
  couponId              String?       @map("coupon_id") @db.Uuid
  saleNumber            String?       @unique @map("sale_number") @db.VarChar(50)
  receiptToken          String?       @unique @map("receipt_token") @db.VarChar(64)
  type                  SaleType      @default(pos)
  status                SaleStatus    @default(completed)
  subtotal              Decimal       @default(0) @db.Decimal(12, 2)
  discountType          DiscountType  @default(pct) @map("discount_type")
  discountValue         Decimal       @default(0) @map("discount_value") @db.Decimal(12, 2)
  discountAmount        Decimal       @default(0) @map("discount_amount") @db.Decimal(12, 2)
  couponDiscount        Decimal       @default(0) @map("coupon_discount") @db.Decimal(12, 2)
  loyaltyDiscount       Decimal       @default(0) @map("loyalty_discount") @db.Decimal(12, 2)
  tipAmount             Decimal       @default(0) @map("tip_amount") @db.Decimal(12, 2)
  totalAmount           Decimal       @default(0) @map("total_amount") @db.Decimal(12, 2)
  amountPaid            Decimal       @default(0) @map("amount_paid") @db.Decimal(12, 2)
  amountDue             Decimal       @default(0) @map("amount_due") @db.Decimal(12, 2)
  paymentMethod         PaymentMethod @default(cash) @map("payment_method")
  cashAmount            Decimal       @default(0) @map("cash_amount") @db.Decimal(12, 2)
  zaadAmount            Decimal       @default(0) @map("zaad_amount") @db.Decimal(12, 2)
  cardAmount            Decimal       @default(0) @map("card_amount") @db.Decimal(12, 2)
  cashTendered          Decimal       @default(0) @map("cash_tendered") @db.Decimal(12, 2)
  changeGiven           Decimal       @default(0) @map("change_given") @db.Decimal(12, 2)
  taxAmount             Decimal       @default(0) @map("tax_amount") @db.Decimal(12, 2)
  loyaltyPointsEarned   Int           @default(0) @map("loyalty_points_earned")
  loyaltyPointsRedeemed Int           @default(0) @map("loyalty_points_redeemed")
  notes                 String?
  cashierId             String?       @map("cashier_id") @db.Uuid
  createdAt             DateTime      @default(now()) @map("created_at")

  business      Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  shift         Shift?          @relation(fields: [shiftId], references: [id])
  location      Location?       @relation(fields: [locationId], references: [id])
  customer      Customer?       @relation(fields: [customerId], references: [id])
  coupon        Coupon?         @relation(fields: [couponId], references: [id])
  cashier       User?           @relation(fields: [cashierId], references: [id])
  items         SaleItem[]
  refunds       Refund[]
  saleKeys      SaleKey[]
  loyaltyLedger LoyaltyLedger[]
  serialNumbers SerialNumber[]
  payments      SalePayment[]
  creditLedger  CreditLedger[]
  paymentPlans  PaymentPlan[]

  @@index([businessId, createdAt])
  @@index([shiftId])
  @@map("sales")
}

model SaleItem {
  id            String   @id @default(uuid()) @db.Uuid
  saleId        String   @map("sale_id") @db.Uuid
  productId     String   @map("product_id") @db.Uuid
  variantId     String?  @map("variant_id") @db.Uuid
  quantity      Int
  unitPrice     Decimal  @map("unit_price") @db.Decimal(12, 2)
  originalPrice Decimal? @map("original_price") @db.Decimal(12, 2)
  costPrice     Decimal  @default(0) @map("cost_price") @db.Decimal(12, 2)
  totalPrice    Decimal  @map("total_price") @db.Decimal(12, 2)
  discount      Decimal  @default(0) @db.Decimal(12, 2)
  notes         String?

  sale        Sale            @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product     Product         @relation(fields: [productId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  taxRate     TaxRate?        @relation(fields: [taxRateId], references: [id])
  taxRateId   String?         @map("tax_rate_id") @db.Uuid
  taxAmount   Decimal         @default(0) @map("tax_amount") @db.Decimal(12, 2)
  refundItems RefundItem[]

  @@index([saleId])
  @@map("sale_items")
}

model Refund {
  id            String   @id @default(uuid()) @db.Uuid
  businessId    String   @map("business_id") @db.Uuid
  saleId        String   @map("sale_id") @db.Uuid
  refundNumber  String?  @unique @map("refund_number") @db.VarChar(50)
  reason        String?
  totalRefunded Decimal  @map("total_refunded") @db.Decimal(12, 2)
  refundMethod  String?  @map("refund_method") @db.VarChar(30)
  restocked     Boolean  @default(true)
  createdById   String?  @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")

  business  Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sale      Sale         @relation(fields: [saleId], references: [id])
  createdBy User?        @relation(fields: [createdById], references: [id])
  items     RefundItem[]

  @@map("refunds")
}

model RefundItem {
  id         String  @id @default(uuid()) @db.Uuid
  refundId   String  @map("refund_id") @db.Uuid
  saleItemId String? @map("sale_item_id") @db.Uuid
  productId  String  @map("product_id") @db.Uuid
  quantity   Int
  unitPrice  Decimal @map("unit_price") @db.Decimal(12, 2)
  totalPrice Decimal @map("total_price") @db.Decimal(12, 2)
  restock    Boolean @default(true)

  refund   Refund    @relation(fields: [refundId], references: [id], onDelete: Cascade)
  saleItem SaleItem? @relation(fields: [saleItemId], references: [id])
  product  Product   @relation(fields: [productId], references: [id])

  @@map("refund_items")
}

model SaleKey {
  id              String    @id @default(uuid()) @db.Uuid
  key             String    @unique @db.VarChar(128)
  cashierId       String    @map("cashier_id") @db.Uuid
  businessId      String    @map("business_id") @db.Uuid
  cartFingerprint String?   @map("cart_fingerprint") @db.VarChar(256)
  used            Boolean   @default(false)
  usedAt          DateTime? @map("used_at")
  saleId          String?   @map("sale_id") @db.Uuid
  expiresAt       DateTime  @map("expires_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  cashier  User     @relation(fields: [cashierId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sale     Sale?    @relation(fields: [saleId], references: [id], onDelete: SetNull)

  @@index([key])
  @@index([expiresAt])
  @@map("sale_keys")
}

