  // ── Commission report settings ──
  commissionCalc      String @default("invoice_value") @map("commission_calc") @db.VarChar(30)
  commissionAgentType String @default("logged_in_user") @map("commission_agent_type") @db.VarChar(30)
  moduleSubscriptions ModuleSubscription[]

  @@map("businesses")
