model Business {
  id            String   @id @default(uuid()) @db.Uuid
  name          String   @db.VarChar(255)
  email         String   @unique @db.VarChar(255)
  phone         String?  @db.VarChar(50)
  address       String?
  city          String?  @db.VarChar(100)
  country       String?  @default("Somaliland") @db.VarChar(100)
  currency      String?  @default("USD") @db.VarChar(10)
  language      String   @default("en") @db.VarChar(5) // en | so | ar (ar drives RTL)
  logoUrl       String?  @map("logo_url")
  logoKey       String?  @map("logo_key")
  receiptHeader String?  @map("receipt_header")
  receiptFooter String?  @default("Thank you for your business!") @map("receipt_footer")
  taxNumber     String?  @map("tax_number") @db.VarChar(100)
  serviceChargePct Decimal? @map("service_charge_pct") @db.Decimal(6, 4) // accepts 10 or 0.10
  enforceRxOnSale Boolean @default(false) @map("enforce_rx_on_sale") // pharmacy: block Rx-only drugs at POS without a valid prescription
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  // Relations
  users              User[]
  activityLogs       ActivityLog[]
  categories         Category[]
  locations          Location[]
  products           Product[]
  stockMovements     StockMovement[]
  stockAdjustments   StockAdjustment[]
  stockTransfers     StockTransfer[]
  stockCounts        StockCount[]
  suppliers          Supplier[]
  purchaseOrders     PurchaseOrder[]
  goodsReceivedNotes GoodsReceivedNote[]
  customers          Customer[]
  shifts             Shift[]
  heldSales          HeldSale[]
  sales              Sale[]
  refunds            Refund[]
  projects           Project[]
  tasks              Task[]
  notifications      Notification[]
  saleKeys           SaleKey[]
  syncDevices        SyncDevice[]
  fiscalConfig       FiscalConfig?
  fiscalReceipts     FiscalReceipt[]
  drivers            Driver[]
  deliveries         Delivery[]
  deliveryZones      DeliveryZone[]
  refreshTokens      RefreshToken[]
  exchangeRates      ExchangeRate[]
  reorderSuggestions ReorderSuggestion[]
  loyaltyRules       LoyaltyRule[]
  loyaltyLedger      LoyaltyLedger[]
  coupons            Coupon[]
  pettyCash          PettyCash[]
  productBundles     ProductBundle[]
  serialNumbers      SerialNumber[]
  barcodeLabelJobs   BarcodeLabelJob[]
  costLayers         CostLayer[]
  recipes            Recipe[]
  accounts           Account[]
  journalEntries     JournalEntry[]
  prescriptions      Prescription[]
  prescriptionGroups PrescriptionGroup[]
  dispenseRecords    DispenseRecord[]
  financingAdvances  FinancingAdvance[]
  eightySixes        EightySix[]
  tableReservations  TableReservation[]
  supplierCatalogs   SupplierCatalog[]
  scheduledReports   ScheduledReport[]
  whatsappLogs       WhatsappLog[]
  salePayments       SalePayment[]
  taxRates           TaxRate[]
  webhookEndpoints   WebhookEndpoint[]
  webhookDeliveries  WebhookDelivery[]
  roomTypes          RoomType[]
  rooms              Room[]
  ratePlans          RatePlan[]
  reservations       Reservation[]
  folios             Folio[]
  folioCharges       FolioCharge[]
  folioPayments      FolioPayment[]
  housekeepingLogs   HousekeepingLog[]
  corporateAccounts  CorporateAccount[]
  modifierGroups     ModifierGroup[]
  restaurantTables   RestaurantTable[]
  restaurantOrders   RestaurantOrder[]
  kitchenTickets     KitchenTicket[]
  creditLedger       CreditLedger[]
  paymentPlans       PaymentPlan[]
  diasporaPayments   DiasporaPayment[]
  settlementAccounts SettlementAccount[]
  reservationGroups  ReservationGroup[]
  lostFoundItems     LostFound[]
  hotelSettings      HotelSettings?
  wholesaleOrders    WholesaleOrder[]
  expenses           Expense[]
  expenseCategories  ExpenseCategory[]
  paymentAccounts    PaymentAccount[]
  customerGroups     CustomerGroup[]
  units              Unit[]
  brands             Brand[]
  variationTemplates VariationTemplate[]
  discounts          Discount[]
  priceGroups        PriceGroup[]
  invoiceLayouts     InvoiceLayout[]
  invoiceSchemes     InvoiceScheme[]
  employees          Employee[]
  orgUnits           OrgUnit[]
  hrmSettings        HrmSettings?
  serviceTypes       ServiceType[]
  subscription         Subscription?
  subscriptionPayments SubscriptionPayment[]
  attendance         Attendance[]
  leaveTypes         LeaveType[]
  leaves             Leave[]
  leaveOverrides     EmployeeLeaveOverride[]
  rosterShifts       RosterShift[]
  rosterSwaps        RosterSwap[]
  hrAdvances         HrAdvance[]
  hrTodos            HrTodo[]
  payrolls           Payroll[]

  // ── Module licensing: which products this business has enabled ──
  // Each module is sellable as a separate product (pos, inventory, hotel,
  // restaurant, pharmacy, credit, insights). Empty = all enabled (legacy).
