model Payroll {
  id               String   @id @default(uuid()) @db.Uuid
  businessId       String   @map("business_id") @db.Uuid
  employeeId       String   @map("employee_id") @db.Uuid
  month            String   @db.VarChar(7)
  basic            Decimal  @default(0) @db.Decimal(12, 2)
  allowance        Decimal  @default(0) @db.Decimal(12, 2)
  overtime         Decimal  @default(0) @db.Decimal(12, 2)
  bonus            Decimal  @default(0) @db.Decimal(12, 2)
  incentive        Decimal  @default(0) @db.Decimal(12, 2)
  deduction        Decimal  @default(0) @db.Decimal(12, 2)
  advanceRecovered Decimal  @default(0) @map("advance_recovered") @db.Decimal(12, 2)
  // Statutory deductions breakdown (for filing); 0 when no statutory regime applies.
  statutoryCountry String?  @map("statutory_country") @db.VarChar(8)
  paye             Decimal  @default(0) @db.Decimal(12, 2)
  nssf             Decimal  @default(0) @db.Decimal(12, 2)
  shif             Decimal  @default(0) @db.Decimal(12, 2)
  housingLevy      Decimal  @default(0) @map("housing_levy") @db.Decimal(12, 2)
  statutoryTotal   Decimal  @default(0) @map("statutory_total") @db.Decimal(12, 2)
  net              Decimal  @default(0) @db.Decimal(12, 2)
  status           String   @default("paid") @db.VarChar(20)
  createdAt        DateTime @default(now()) @map("created_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@map("payrolls")
}

model RosterShift {
