// Rotating savings group (hagbad / ayuuto / chama). Members contribute a fixed
// amount each cycle; the whole pot rotates to one member per cycle. The platform
// holds contributions as a liability (Savings Group Payable) until paid out —
// auditable money is the whole point of digitizing a trust-based circle. Free.
model SavingsGroup {
  id                 String   @id @default(uuid()) @db.Uuid
  businessId         String   @map("business_id") @db.Uuid
  name               String   @db.VarChar(150)
  contributionAmount Decimal  @map("contribution_amount") @db.Decimal(12, 2)
  frequency          String   @default("monthly") @db.VarChar(20) // weekly | monthly
  currency           String   @default("USD") @db.VarChar(3)
  currentCycle       Int      @default(1) @map("current_cycle")
  status             String   @default("active") @db.VarChar(20) // active | completed
  createdById        String?  @map("created_by") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at")

  members       SavingsGroupMember[]
  contributions SavingsContribution[]
  payouts       SavingsPayout[]
  @@index([businessId])
  @@map("savings_groups")
}

model SavingsGroupMember {
  id             String   @id @default(uuid()) @db.Uuid
  groupId        String   @map("group_id") @db.Uuid
  name           String   @db.VarChar(150)
  phone          String?  @db.VarChar(50)
  payoutPosition Int      @map("payout_position") // 1-based rotation order
  paidOut        Boolean  @default(false) @map("paid_out")
  createdAt      DateTime @default(now()) @map("created_at")

  group SavingsGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  @@index([groupId])
  @@map("savings_group_members")
}

model SavingsContribution {
  id        String   @id @default(uuid()) @db.Uuid
  groupId   String   @map("group_id") @db.Uuid
  memberId  String   @map("member_id") @db.Uuid
  cycle     Int
  amount    Decimal  @db.Decimal(12, 2)
  method    String   @default("cash") @db.VarChar(30)
  createdAt DateTime @default(now()) @map("created_at")

  group SavingsGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  @@index([groupId, cycle])
  @@map("savings_contributions")
}

model SavingsPayout {
  id        String   @id @default(uuid()) @db.Uuid
  groupId   String   @map("group_id") @db.Uuid
  memberId  String   @map("member_id") @db.Uuid
  cycle     Int
  amount    Decimal  @db.Decimal(12, 2)
  method    String   @default("cash") @db.VarChar(30)
  createdAt DateTime @default(now()) @map("created_at")

  group SavingsGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  @@index([groupId])
  @@map("savings_payouts")
}

// B2B trade rail: an order placed by one on-platform business (buyer / duka) to
// another (seller / distributor). The network-liquidity play — a distributor and
// the shops it supplies both transact on the same system, and the accepted order
// posts to BOTH ledgers at once (seller AR↔revenue, buyer inventory↔payable).
model TradeOrder {
  id               String   @id @default(uuid()) @db.Uuid
  sellerBusinessId String   @map("seller_business_id") @db.Uuid
  buyerBusinessId  String   @map("buyer_business_id") @db.Uuid
  orderNumber      String   @map("order_number") @db.VarChar(40)
  status           String   @default("pending") @db.VarChar(20) // pending | accepted | rejected
  total            Decimal  @default(0) @db.Decimal(14, 2)
  note             String?  @db.VarChar(300)
  createdById      String?  @map("created_by") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")

  items TradeOrderItem[]
  @@index([sellerBusinessId, status])
  @@index([buyerBusinessId, status])
  @@map("trade_orders")
}

model TradeOrderItem {
  id           String  @id @default(uuid()) @db.Uuid
  tradeOrderId String  @map("trade_order_id") @db.Uuid
  productId    String  @map("product_id") @db.Uuid
  productName  String  @map("product_name") @db.VarChar(255)
  quantity     Int
  unitPrice    Decimal @map("unit_price") @db.Decimal(12, 2)
  lineTotal    Decimal @map("line_total") @db.Decimal(12, 2)

  order TradeOrder @relation(fields: [tradeOrderId], references: [id], onDelete: Cascade)
  @@index([tradeOrderId])
  @@map("trade_order_items")
}

// Takaful — Islamic cooperative micro-insurance. Contributions (tabarru',
// donations) pool to cover members' losses; claims are paid from the pool. The
// pool is a liability held in trust (2500). SCAFFOLDING — real underwriting needs
// a takaful partner + Sharia board; the cooperative ledger + GL are here.
model TakafulPolicy {
  id              String    @id @default(uuid()) @db.Uuid
  businessId      String    @map("business_id") @db.Uuid
  reference       String    @db.VarChar(40)
  policyholder    String    @db.VarChar(200)
  phone           String?   @db.VarChar(50)
  coverType       String    @map("cover_type") @db.VarChar(30) // inventory | vehicle | health | property
  coverageAmount  Decimal   @map("coverage_amount") @db.Decimal(14, 2)
  contribution    Decimal   @db.Decimal(14, 2) // periodic tabarru'
  contributedTotal Decimal  @default(0) @map("contributed_total") @db.Decimal(14, 2)
  termMonths      Int       @map("term_months")
  status          String    @default("active") @db.VarChar(20) // active | expired | cancelled
  startDate       DateTime  @default(now()) @map("start_date")
  createdById     String?   @map("created_by") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")

  claims TakafulClaim[]
  @@index([businessId, status])
  @@map("takaful_policies")
}

model TakafulClaim {
  id        String   @id @default(uuid()) @db.Uuid
  policyId  String   @map("policy_id") @db.Uuid
  amount    Decimal  @db.Decimal(14, 2)
  reason    String   @db.VarChar(300)
  status    String   @default("pending") @db.VarChar(20) // pending | paid | rejected
  method    String?  @db.VarChar(30)
  decidedAt DateTime? @map("decided_at")
  createdAt DateTime @default(now()) @map("created_at")

  policy TakafulPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  @@index([policyId])
  @@map("takaful_claims")
}

// Merchant settlement / wallet account (the Kaspi / Mercado model): an in-app
// balance the merchant tops up, holds, and pays out from. SCAFFOLDING — holding
// real float requires an EMI licence / bank partner; the ledger + GL are here.
model WalletTransaction {
  id           String   @id @default(uuid()) @db.Uuid
  businessId   String   @map("business_id") @db.Uuid
  type         String   @db.VarChar(20) // deposit | withdraw
  amount       Decimal  @db.Decimal(14, 2)
  method       String   @default("cash") @db.VarChar(30)
  note         String?  @db.VarChar(255)
  balanceAfter Decimal  @map("balance_after") @db.Decimal(14, 2)
  createdById  String?  @map("created_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([businessId, createdAt])
  @@map("wallet_transactions")
}

// Asset / vehicle finance (Murabaha cost-plus or Ijara lease-to-own). The proven
// durable model for the corridor (M-Kopa / Watu): finance a productive asset and
// collect against the income it unlocks. SCAFFOLDING — moving real money needs a
// lending licence + capital; the software + GL + lifecycle are here and tested.
model AssetFinance {
  id               String    @id @default(uuid()) @db.Uuid
  businessId       String    @map("business_id") @db.Uuid
  reference        String    @db.VarChar(40)
  borrowerName     String    @map("borrower_name") @db.VarChar(200)
  borrowerPhone    String?   @map("borrower_phone") @db.VarChar(50)
  structure        String    @default("murabaha") @db.VarChar(20) // murabaha | ijara
  assetType        String    @map("asset_type") @db.VarChar(50)   // vehicle | equipment | phone | other
  assetDescription String?   @map("asset_description") @db.VarChar(255)
  assetCost        Decimal   @map("asset_cost") @db.Decimal(14, 2) // what we pay for the asset
  markup           Decimal   @db.Decimal(14, 2)                    // fixed, disclosed profit (not interest)
  totalPayable     Decimal   @map("total_payable") @db.Decimal(14, 2)
  termMonths       Int       @map("term_months")
  amountRepaid     Decimal   @default(0) @map("amount_repaid") @db.Decimal(14, 2)
  status           String    @default("offered") @db.VarChar(20)   // offered | active | settled | defaulted
  disbursedAt      DateTime? @map("disbursed_at")
  settledAt        DateTime? @map("settled_at")
  defaultedAt      DateTime? @map("defaulted_at")
  createdById      String?   @map("created_by") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at")

  repayments AssetFinanceRepayment[]
  @@index([businessId, status])
  @@map("asset_finance")
}

model AssetFinanceRepayment {
  id        String   @id @default(uuid()) @db.Uuid
  financeId String   @map("finance_id") @db.Uuid
  amount    Decimal  @db.Decimal(14, 2)
  method    String   @default("cash") @db.VarChar(30)
  createdAt DateTime @default(now()) @map("created_at")

  finance AssetFinance @relation(fields: [financeId], references: [id], onDelete: Cascade)
  @@index([financeId])
  @@map("asset_finance_repayments")
}

// Zakat / Sadaqah given by the business — a charitable outflow recorded for the
// books and for the owner's giving history (Zakat is computed from the ledger by
// lib/zakat; this records what was actually paid out).
model ZakatPayment {
  id          String   @id @default(uuid()) @db.Uuid
  businessId  String   @map("business_id") @db.Uuid
  type        String   @db.VarChar(10) // zakat | sadaqah
  amount      Decimal  @db.Decimal(14, 2)
  recipient   String?  @db.VarChar(200)
  method      String   @default("cash") @db.VarChar(30)
  note        String?  @db.VarChar(300)
  createdById String?  @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([businessId])
  @@map("zakat_payments")
}

// Stamp / punch card loyalty ("buy 9 coffees, get 1 free"). A program defines how
// many stamps earn a reward; each customer accrues toward it and rolls over.
model StampCard {
  id             String   @id @default(uuid()) @db.Uuid
  businessId     String   @map("business_id") @db.Uuid
  name           String   @db.VarChar(150)
  productId      String?  @map("product_id") @db.Uuid // null = any qualifying purchase
  stampsRequired Int      @map("stamps_required")
  reward         String   @db.VarChar(200)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  cards CustomerStampCard[]
  @@index([businessId])
  @@map("stamp_cards")
}

model CustomerStampCard {
  id             String   @id @default(uuid()) @db.Uuid
  stampCardId    String   @map("stamp_card_id") @db.Uuid
  customerId     String   @map("customer_id") @db.Uuid
  stamps         Int      @default(0)
  completedCount Int      @default(0) @map("completed_count") // rewards earned over time
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  stampCard StampCard @relation(fields: [stampCardId], references: [id], onDelete: Cascade)
  @@unique([stampCardId, customerId])
  @@index([stampCardId])
  @@map("customer_stamp_cards")
}

